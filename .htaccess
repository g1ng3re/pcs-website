# Property Clinic Solutions — static site

# Kill LiteSpeed's server-level page cache: stale WordPress pages from the
# deleted WP install live in this cache and keep being served for old URLs.
<IfModule LiteSpeed>
  RewriteEngine On
  CacheDisable public /
  RewriteRule .* - [E=Cache-Control:no-cache]
</IfModule>

# Serve index.html as the directory default (beats any leftover index.php)
DirectoryIndex index.html

# Force HTTPS + non-www, and serve clean (extensionless) URLs
<IfModule mod_rewrite.c>
  RewriteEngine On

  # HTTPS + canonical non-www host
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} ^www\.propertyclinicsolutions\.com [NC]
  RewriteRule ^ https://propertyclinicsolutions.com%{REQUEST_URI} [L,R=301]

  # /index or /index.html -> /
  RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  # --- 301s from old WordPress URLs (indexed by Google) to their new homes ---
  RewriteRule ^about-us/?$ /about [R=301,L]
  RewriteRule ^mortgage-calculator/?$ /calculator [R=301,L]
  RewriteRule ^self-employed-mortgages/?$ /self-employed [R=301,L]
  RewriteRule ^events-2/?$ /events [R=301,L]
  RewriteRule ^complaint/?$ /complaints [R=301,L]
  RewriteRule ^cookies-policy/?$ /cookie-policy [R=301,L]
  RewriteRule ^privacy-policy/?$ /privacy [R=301,L]
  RewriteRule ^resources/?$ /blog [R=301,L]
  # Old WP privacy page reached via query string (/?page_id=3)
  RewriteCond %{QUERY_STRING} (^|&)page_id=3(&|$)
  RewriteRule ^$ /privacy? [R=301,L]
  # Anything under the old WP internals has no static equivalent -> home
  RewriteRule ^(wp-admin|wp-content|wp-includes|wp-json)(/|$) / [R=301,L]
  RewriteRule ^wp-login\.php$ / [R=301,L]

  # Redirect /page.html -> /page (so the address bar shows clean URLs)
  RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Strip trailing slashes on non-directories (/mortgages/ -> /mortgages),
  # so relative CSS/image paths resolve and old WordPress URLs normalise
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # Internally serve the .html file for an extensionless request
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType application/font-sfnt "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/javascript image/svg+xml
</IfModule>

# Friendly 404 -> home (optional; static multipage so usually fine without)
ErrorDocument 404 /404.html
